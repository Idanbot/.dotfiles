{{- $name := promptStringOnce . "name" "Full name" "Idan Botbol" -}}
{{- $email := promptStringOnce . "email" "Git email" "botbolidan@gmail.com" -}}
{{- $sessionizerDirs := promptStringOnce . "sessionizer_dirs" "tmux-sessionizer search dirs (space-separated)" "~/Code ~/Scripts ~/Education" -}}

{{- $isWsl := false -}}
{{- if eq (env "DOTFILES_WSL") "true" -}}
{{-   $isWsl = true -}}
{{- end -}}
{{- if eq .chezmoi.os "linux" -}}
{{-   if (.chezmoi.kernel.osrelease | lower | contains "microsoft") -}}
{{-     $isWsl = true -}}
{{-   end -}}
{{- end -}}

data:
  name: {{ $name | quote }}
  email: {{ $email | quote }}
  is_wsl: {{ $isWsl }}
  is_native: {{ not $isWsl }}
  sessionizer_dirs: {{ $sessionizerDirs | quote }}

# This public repository intentionally has no encryption dependency. Credentials,
# private keys, API tokens, and authentication state are restored manually.
