#!/usr/bin/env bash
# tmux-sessionizer — Quick project session switcher (ThePrimeagen-inspired)
# Search dirs configured via chezmoi: {{ .sessionizer_dirs }}

if [[ $# -eq 1 ]]; then
  selected=$1
else
  # Search directories from chezmoi config
  # shellcheck disable=SC2086
  selected=$(find {{ .sessionizer_dirs }} -mindepth 1 -maxdepth 1 -type d 2>/dev/null | fzf)
fi

if [[ -z $selected ]]; then
  exit 0
fi

selected_name=$(basename "$selected" | tr ":,. " "____")
tmux_running=$(pgrep tmux)

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
  tmux new-session -s "$selected_name" -c "$selected"
  exit 0
fi

if ! tmux has-session -t="$selected_name" 2>/dev/null; then
  tmux new-session -ds "$selected_name" -c "$selected"
fi

tmux switch-client -t "$selected_name"
