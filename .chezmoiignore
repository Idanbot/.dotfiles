# Ignore README and CI files — they're repo metadata, not dotfiles
README.md
LICENSE
packages.yaml
packages.meta.yaml
packages.lock
agents.yaml
profiles/
scripts/
tests/
.github/
.gitignore
.gitleaks.toml
.yamllint.yml
artifacts/
docs/

# Platform-specific ignores
{{ if .is_wsl }}
# Skip desktop/GUI configs on WSL
.config/kitty/
{{ end }}

# Preserve local shell history, completion caches, and interactive session state.
# These are useful machine-local files and should not be overwritten by chezmoi.
.bash_history
.zsh_history
.lesshst
.python_history
.mysql_history
.psql_history
.sqlite_history
.node_repl_history
.rediscli_history
.wget-hsts
.zcompdump*
.zsh_sessions/
.local/share/zsh/
.local/state/zsh/

# Explicitly local-only overlays and credentials. These paths are never
# materialized from this public source state.
.config/dotfiles/local.zsh
.config/dotfiles/local.bash
.config/dotfiles/local.tmux.conf
.config/dotfiles/machine.conf
.config/git/config.local
.ssh/config.local
