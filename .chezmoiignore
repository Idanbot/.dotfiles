dot_python_history
dot_mysql_history
dot_psql_history
dot_sqlite_history
dot_node_repl_history
dot_rediscli_history
dot_wget-hsts
dot_zcompdump*
dot_zsh_sessions/
dot_local/share/zsh/
dot_local/state/zsh/
