# SSH Client Configuration
# Auto-generated by chezmoi from {{ .chezmoi.sourceFile }}
# DO NOT EDIT DIRECTLY. Your changes will be overwritten.

Include ~/.ssh/config.local

# Global Defaults
Host *
    # Automatically add keys to active agent after first use
    AddKeysToAgent yes
    # Keep connections alive in background
    ServerAliveInterval 60
    ServerAliveCountMax 10
    # Enable connection multiplexing (faster subsequent connections)
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h-%p
    ControlPersist 600

# GitHub
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519

# GitLab
Host gitlab.com
    HostName gitlab.com
    User git
    IdentityFile ~/.ssh/id_ed25519

# Raspberry Pi 4 (Cloudflare Access SSH)
Host rpi4
    HostName rpi4-ssh.idanbot.uk
    User idan
    ProxyCommand /usr/bin/cloudflared access ssh --hostname %h

# ThinkPad T420 (Cloudflare Access SSH)
Host t420
    HostName t420.idanbot.uk
    User idan
    ProxyCommand /usr/bin/cloudflared access ssh --hostname %h


