#!/usr/bin/env bash
source "{{ .chezmoi.sourceDir }}/scripts/lib.sh"

log_step "Installing Nerd Fonts"

FONT_NAME="FiraMono"
FONT_VERSION="3.4.0"
FONT_DIR="$HOME/.local/share/fonts"

if fc-list | grep -qi "FiraMono Nerd"; then
  log_skip "${FONT_NAME} Nerd Font already installed"
else
  log_info "Installing ${FONT_NAME} Nerd Font v${FONT_VERSION}..."
  mkdir -p "$FONT_DIR"
  curl -fsSLo /tmp/nerd-font.zip "https://github.com/ryanoasis/nerd-fonts/releases/download/v${FONT_VERSION}/${FONT_NAME}.zip"
  unzip -qo /tmp/nerd-font.zip -d "$FONT_DIR/${FONT_NAME}"
  rm -f /tmp/nerd-font.zip
  fc-cache -fv "$FONT_DIR" >/dev/null 2>&1
  log_success "${FONT_NAME} Nerd Font installed"
fi

print_summary "Nerd Fonts"
