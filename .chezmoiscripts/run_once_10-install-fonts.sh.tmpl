#!/usr/bin/env bash
if [[ -z "${DOTFILES_SOURCE_DIR:-}" ]]; then
  DOTFILES_SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
fi
# shellcheck source=scripts/lib.sh
source "$DOTFILES_SOURCE_DIR/scripts/lib.sh"

log_step "Installing Nerd Fonts"
FONT_NAME="$(package_version fonts nerd_font FiraMono)"
FONT_VERSION="$(package_version fonts nerd_font_version 3.4.0)"
FONT_DIR="$HOME/.local/share/fonts/$FONT_NAME"

if fc-list 2>/dev/null | grep -qi "${FONT_NAME} Nerd"; then
  log_skip "$FONT_NAME Nerd Font already installed"
else
  tmpdir="$(mktemp -d)"
  asset="${FONT_NAME}.zip"
  log_info "Installing $FONT_NAME Nerd Font $FONT_VERSION"
  download_verified \
    "https://github.com/ryanoasis/nerd-fonts/releases/download/v${FONT_VERSION}/$asset" \
    "$tmpdir/$asset" \
    "https://github.com/ryanoasis/nerd-fonts/releases/download/v${FONT_VERSION}/SHA-256.txt" \
    "$asset"
  mkdir -p "$FONT_DIR"
  unzip -qo "$tmpdir/$asset" -d "$FONT_DIR"
  rm -rf "$tmpdir"
  fc-cache -f "$FONT_DIR" >/dev/null 2>&1
  record_install "$FONT_NAME" "$FONT_VERSION" nerd-fonts "$FONT_DIR"
  ((_INSTALLED++)) || true
  log_success "$FONT_NAME Nerd Font installed"
fi

print_summary "Nerd Fonts"
