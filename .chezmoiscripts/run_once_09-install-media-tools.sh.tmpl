#!/usr/bin/env bash
if [[ -z "${DOTFILES_SOURCE_DIR:-}" ]]; then
  DOTFILES_SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
fi
# shellcheck source=scripts/lib.sh
source "$DOTFILES_SOURCE_DIR/scripts/lib.sh"

log_step "Installing Media Tools"
if is_wsl; then
  log_skip "Media tools are disabled on WSL"
  print_summary "Media Tools"
  exit 0
fi

YTDLP_VERSION="$(package_version media yt_dlp 2026.07.04)"
if ! is_installed uv; then
  log_error "uv is required for yt-dlp; include the languages section"
else
  uv tool install --force "yt-dlp==${YTDLP_VERSION}"
  record_install yt-dlp "$YTDLP_VERSION" uv "$(uv tool dir)/yt-dlp"
  log_success "yt-dlp $YTDLP_VERSION installed"
fi

require_sudo
apt_install cava mpd

RMPC_VERSION="$(package_version media rmpc 0.11.0)"
case "$(get_arch)" in
  amd64)
    RMPC_TARGET=x86_64-unknown-linux-gnu
    RMPC_SHA=b03d4b777cf0afe61107abb4ee847b7c6539b8f5c76555fd759cd15a6c1ff604
    ;;
  arm64)
    RMPC_TARGET=aarch64-unknown-linux-gnu
    RMPC_SHA=12d9bb3bcabfe90c0573afac9b11e20333262872966a8769967611b578ff7328
    ;;
esac
if ! is_installed rmpc || ! version_ge "$(rmpc --version 2>/dev/null || true)" "$RMPC_VERSION"; then
  tmpdir="$(mktemp -d)"
  asset="rmpc-v${RMPC_VERSION}-${RMPC_TARGET}.tar.gz"
  download_verified \
    "https://github.com/mierak/rmpc/releases/download/v${RMPC_VERSION}/$asset" \
    "$tmpdir/$asset" "sha256:$RMPC_SHA" "$asset"
  tar -xzf "$tmpdir/$asset" -C "$tmpdir"
  install_managed_binary "$tmpdir/rmpc" rmpc "$RMPC_VERSION" github:mierak/rmpc
  rm -rf "$tmpdir"
  ((_INSTALLED++)) || true
  log_success "rmpc $RMPC_VERSION installed"
else
  log_skip "rmpc $RMPC_VERSION already installed or newer"
fi

print_summary "Media Tools"
