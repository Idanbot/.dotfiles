#!/usr/bin/env bash
if [[ -z "${DOTFILES_SOURCE_DIR:-}" ]]; then
  DOTFILES_SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
fi
# shellcheck source=scripts/lib.sh
source "$DOTFILES_SOURCE_DIR/scripts/lib.sh"

log_step "Installing Terminal Tools"
require_sudo
ARCH="$(get_arch)"

# fzf source is a checksum-pinned chezmoi external.
if [[ -x "$HOME/.fzf/install" ]]; then
  if ! is_installed fzf; then
    "$HOME/.fzf/install" --all --no-update-rc --no-bash --no-fish
    record_install fzf "$(package_version core fzf 0.74.0)" chezmoi-external "$HOME/.fzf"
    log_success "fzf installed"
  else
    log_skip "fzf already installed"
  fi
else
  log_error "Checksum-pinned fzf external is missing"
fi

apt_install fd-find ripgrep bat btop htop jq
if is_installed fdfind; then
  managed_link "$(command -v fdfind)" "$HOME/.local/bin/fd" fd distro
fi
if is_installed batcat; then
  managed_link "$(command -v batcat)" "$HOME/.local/bin/bat" bat distro
fi

case "$ARCH" in
  amd64)
    RELEASE_ARCH=x86_64
    EZA_SHA=0c38665440226cd8bef5d1d4f3bc6ff77c927fb0d68b752739105db7ab5b358d
    ;;
  arm64)
    RELEASE_ARCH=aarch64
    EZA_SHA=366e8430225f9955c3dc659b452150c169894833ccfef455e01765e265a3edda
    ;;
  *)
    log_error "Unsupported release architecture: $ARCH"
    exit 1
    ;;
esac

EZA_VERSION="$(package_version core eza 0.23.4)"
install_github_archive \
  eza eza-community/eza "v${EZA_VERSION#v}" \
  "eza_${RELEASE_ARCH}-unknown-linux-gnu.tar.gz" ./eza \
  "sha256:$EZA_SHA" \
  'eza --version'

LAZYGIT_VERSION="$(package_version core lazygit 0.63.0)"
install_github_archive \
  lazygit jesseduffield/lazygit "v${LAZYGIT_VERSION#v}" \
  "lazygit_{version}_linux_${RELEASE_ARCH}.tar.gz" lazygit \
  "https://github.com/jesseduffield/lazygit/releases/download/{tag}/checksums.txt" \
  'lazygit --version'

STARSHIP_VERSION="$(package_version core starship 1.26.0)"
install_github_archive \
  starship starship/starship "v${STARSHIP_VERSION#v}" \
  "starship-${RELEASE_ARCH}-unknown-linux-gnu.tar.gz" starship \
  "https://github.com/starship/starship/releases/download/{tag}/starship-${RELEASE_ARCH}-unknown-linux-gnu.tar.gz.sha256" \
  'starship --version'

SOPS_VERSION="$(package_version core sops 3.13.2)"
install_github_binary \
  sops getsops/sops "v${SOPS_VERSION#v}" "sops-{tag}.linux.${ARCH}" sops \
  "https://github.com/getsops/sops/releases/download/{tag}/sops-{tag}.checksums.txt" \
  'sops --version'

LAZYDOCKER_VERSION="$(package_version core lazydocker 0.25.2)"
install_github_archive \
  lazydocker jesseduffield/lazydocker "v${LAZYDOCKER_VERSION#v}" \
  "lazydocker_{version}_Linux_${RELEASE_ARCH}.tar.gz" lazydocker \
  "https://github.com/jesseduffield/lazydocker/releases/download/{tag}/checksums.txt" \
  'lazydocker --version'

TEALDEER_VERSION="$(package_version core tealdeer 1.8.1)"
install_github_binary \
  tldr dbrgn/tealdeer "v${TEALDEER_VERSION#v}" \
  "tealdeer-linux-${RELEASE_ARCH}-musl" tldr \
  "https://github.com/dbrgn/tealdeer/releases/download/{tag}/tealdeer-linux-${RELEASE_ARCH}-musl.sha256" \
  'tldr --version'
tldr --update || log_warn "tealdeer cache update is temporarily unavailable"

print_summary "Terminal Tools"
