#!/usr/bin/env bash
if [[ -z "${DOTFILES_SOURCE_DIR:-}" ]]; then
  DOTFILES_SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
fi
# shellcheck source=scripts/lib.sh
source "$DOTFILES_SOURCE_DIR/scripts/lib.sh"

log_step "Installing Terminal Tools"

require_sudo
ARCH=$(get_arch)

# ── fzf ───────────────────────────────────────────────────────────────────────
# fzf is handled by .chezmoiexternal.yaml (cloned to ~/.fzf)
# Run the install script if not already done
if [[ -d "$HOME/.fzf" ]] && ! is_installed fzf; then
  log_info "Installing fzf from ~/.fzf..."
  "$HOME/.fzf/install" --all --no-update-rc --no-bash --no-fish
  log_success "fzf installed"
elif is_installed fzf; then
  log_skip "fzf already installed"
else
  log_warn "fzf source not found at ~/.fzf — will be set up by chezmoi externals"
fi

# ── fd-find ───────────────────────────────────────────────────────────────────
apt_install fd-find
if is_installed fdfind && ! is_installed fd; then
  mkdir -p "$HOME/.local/bin"
  ln -sf "$(command -v fdfind)" "$HOME/.local/bin/fd"
  log_success "Created fd -> fdfind symlink"
fi

# ── ripgrep ───────────────────────────────────────────────────────────────────
apt_install ripgrep

# ── bat ───────────────────────────────────────────────────────────────────────
if ! is_installed bat && ! is_installed batcat; then
  apt_install bat
  # Create bat symlink if only batcat exists
  if is_installed batcat && ! is_installed bat; then
    mkdir -p "$HOME/.local/bin"
    ln -sf "$(command -v batcat)" "$HOME/.local/bin/bat"
    log_success "Created bat -> batcat symlink"
  fi
else
  log_skip "bat already installed"
fi

# ── eza ───────────────────────────────────────────────────────────────────────
if ! is_installed eza; then
  log_info "Installing eza..."
  sudo mkdir -p /etc/apt/keyrings
  wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc | sudo gpg --dearmor -o /etc/apt/keyrings/gierens.gpg
  echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" | sudo tee /etc/apt/sources.list.d/gierens.list > /dev/null
  sudo chmod 644 /etc/apt/keyrings/gierens.gpg /etc/apt/sources.list.d/gierens.list
  sudo apt-get update -qq
  sudo apt-get install -y eza
  log_success "eza installed"
else
  log_skip "eza already installed"
fi

# ── lazygit ───────────────────────────────────────────────────────────────────
LAZYGIT_VERSION=$(package_version core lazygit latest)
if [[ "$ARCH" == "amd64" ]]; then
  LG_ARCH="x86_64"
else
  LG_ARCH="$ARCH"
fi
install_github_archive lazygit jesseduffield/lazygit "v${LAZYGIT_VERSION#v}" "lazygit_{version}_Linux_${LG_ARCH}.tar.gz" lazygit

# ── btop ──────────────────────────────────────────────────────────────────────
apt_install btop

# ── htop ──────────────────────────────────────────────────────────────────────
apt_install htop

# ── starship ──────────────────────────────────────────────────────────────────
if ! is_installed starship; then
  log_info "Installing starship..."
  curl -fsSL https://starship.rs/install.sh | sh -s -- -y
  log_success "starship installed"
else
  log_skip "starship already installed"
fi


# ── sops ──────────────────────────────────────────────────────────────────────
SOPS_VERSION=$(package_version core sops latest)
install_github_binary sops getsops/sops "$SOPS_VERSION" "sops-{tag}.linux.${ARCH}" sops

# ── lazydocker ────────────────────────────────────────────────────────────────
LAZYDOCKER_VERSION=$(package_version core lazydocker "0.25.2")
if [[ "$ARCH" == "amd64" ]]; then
  LD_ARCH="x86_64"
else
  LD_ARCH="$ARCH"
fi
install_github_archive lazydocker jesseduffield/lazydocker "v${LAZYDOCKER_VERSION#v}" "lazydocker_{version}_Linux_${LD_ARCH}.tar.gz" lazydocker

# ── tealdeer ──────────────────────────────────────────────────────────────────
TEALDEER_VERSION=$(package_version core tealdeer "1.6.1")
if [[ "$ARCH" == "amd64" ]]; then
  TD_ARCH="x86_64"
elif [[ "$ARCH" == "arm64" ]]; then
  TD_ARCH="aarch64"
else
  TD_ARCH="$ARCH"
fi
install_github_binary tldr dbrgn/tealdeer "v${TEALDEER_VERSION#v}" "tealdeer-linux-${TD_ARCH}-musl" tldr
tldr --update || true

# ── jq (usually from core but just in case) ───────────────────────────────────
apt_install jq

print_summary "Terminal Tools"
