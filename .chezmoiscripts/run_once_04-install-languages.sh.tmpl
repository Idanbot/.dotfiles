#!/usr/bin/env bash
if [[ -z "${DOTFILES_SOURCE_DIR:-}" ]]; then
  DOTFILES_SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
fi
# shellcheck source=scripts/lib.sh
source "$DOTFILES_SOURCE_DIR/scripts/lib.sh"

log_step "Installing Languages & Runtimes"
require_sudo
ARCH="$(get_arch)"

GO_VERSION="$(package_version languages go 1.26.5)"
if ! is_installed go || ! version_ge "$(go version 2>/dev/null || true)" "$GO_VERSION"; then
  tmpdir="$(mktemp -d)"
  asset="go${GO_VERSION}.linux-${ARCH}.tar.gz"
  go_sha256="$(go_release_checksum "$asset")"
  log_info "Installing Go $GO_VERSION"
  download_verified \
    "https://go.dev/dl/$asset" "$tmpdir/$asset" \
    "sha256:$go_sha256" "$asset"
  sudo rm -rf /usr/local/go
  sudo tar -C /usr/local -xzf "$tmpdir/$asset"
  rm -rf "$tmpdir"
  record_install go "$GO_VERSION" go-dist /usr/local/go
  ((_INSTALLED++)) || true
  log_success "Go $GO_VERSION installed"
else
  log_skip "Go $GO_VERSION already installed or newer"
fi
export PATH="/usr/local/go/bin:$PATH"

RUST_CHANNEL="$(package_version languages rust stable)"
if ! is_installed rustup; then
  case "$ARCH" in
    amd64) RUST_TARGET=x86_64-unknown-linux-gnu ;;
    arm64) RUST_TARGET=aarch64-unknown-linux-gnu ;;
    *) log_error "Unsupported rustup architecture: $ARCH"; exit 1 ;;
  esac
  tmpdir="$(mktemp -d)"
  rustup_url="https://static.rust-lang.org/rustup/dist/${RUST_TARGET}/rustup-init"
  log_info "Installing Rust toolchain $RUST_CHANNEL"
  download_verified "$rustup_url" "$tmpdir/rustup-init" "$rustup_url.sha256" rustup-init
  chmod +x "$tmpdir/rustup-init"
  "$tmpdir/rustup-init" -y --default-toolchain "$RUST_CHANNEL" --profile minimal
  rm -rf "$tmpdir"
  record_install rustup "$RUST_CHANNEL" rustup "$HOME/.cargo"
  ((_INSTALLED++)) || true
  log_success "Rust installed"
else
  log_skip "Rustup already installed"
fi
[[ -f "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"
rustup toolchain install "$RUST_CHANNEL" --profile minimal
rustup default "$RUST_CHANNEL"

NODE_VERSION="$(package_version languages node_lts 24.18.0)"
case "$ARCH" in
  amd64) NODE_ARCH=x64 ;;
  arm64) NODE_ARCH=arm64 ;;
  *) log_error "Unsupported Node.js architecture: $ARCH"; exit 1 ;;
esac
NODE_ROOT="$HOME/.local/share/dotfiles/tools/node/$NODE_VERSION"
NODE_ASSET="node-v${NODE_VERSION}-linux-${NODE_ARCH}.tar.xz"
if [[ ! -x "$NODE_ROOT/bin/node" ]] || ! version_ge "$($NODE_ROOT/bin/node --version 2>/dev/null || true)" "$NODE_VERSION"; then
  tmpdir="$(mktemp -d)"
  log_info "Installing Node.js $NODE_VERSION into a stable user-local runtime"
  download_verified \
    "https://nodejs.org/dist/v${NODE_VERSION}/${NODE_ASSET}" "$tmpdir/$NODE_ASSET" \
    "https://nodejs.org/dist/v${NODE_VERSION}/SHASUMS256.txt" "$NODE_ASSET"
  rm -rf "$NODE_ROOT"
  mkdir -p "$NODE_ROOT"
  tar -xJf "$tmpdir/$NODE_ASSET" -C "$NODE_ROOT" --strip-components=1
  rm -rf "$tmpdir"
  record_install node "$NODE_VERSION" node-dist "$NODE_ROOT"
  ((_INSTALLED++)) || true
  log_success "Node.js $NODE_VERSION installed"
else
  log_skip "Node.js $NODE_VERSION runtime already installed"
fi
for binary in node npm npx corepack; do
  [[ -x "$NODE_ROOT/bin/$binary" ]] && managed_link "$NODE_ROOT/bin/$binary" "$HOME/.local/bin/$binary" node "$NODE_VERSION"
done
activate_node_paths
if ! is_installed node || ! is_installed npm; then
  log_error "Node.js/npm shims are unavailable after installation"
  exit 1
fi

TYPESCRIPT_VERSION="$(package_version languages typescript 7.0.2)"
npm_install_global typescript "$TYPESCRIPT_VERSION" tsc

UV_VERSION="$(package_version languages uv 0.11.28)"
if ! is_installed uv || ! version_ge "$(uv --version 2>/dev/null || true)" "$UV_VERSION"; then
  case "$ARCH" in
    amd64) UV_TARGET=x86_64-unknown-linux-gnu ;;
    arm64) UV_TARGET=aarch64-unknown-linux-gnu ;;
  esac
  tmpdir="$(mktemp -d)"
  asset="uv-${UV_TARGET}.tar.gz"
  log_info "Installing uv $UV_VERSION"
  download_verified \
    "https://github.com/astral-sh/uv/releases/download/${UV_VERSION}/$asset" "$tmpdir/$asset" \
    "https://github.com/astral-sh/uv/releases/download/${UV_VERSION}/$asset.sha256" "$asset"
  tar -xzf "$tmpdir/$asset" -C "$tmpdir"
  install_managed_binary "$tmpdir/uv-${UV_TARGET}/uv" uv "$UV_VERSION" github:astral-sh/uv
  install_managed_binary "$tmpdir/uv-${UV_TARGET}/uvx" uvx "$UV_VERSION" github:astral-sh/uv
  rm -rf "$tmpdir"
  ((_INSTALLED++)) || true
  log_success "uv $UV_VERSION installed"
else
  log_skip "uv $UV_VERSION already installed or newer"
fi
export PATH="$HOME/.local/bin:$PATH"

PYTHON_VERSION="$(package_version languages python 3.14.6)"
if uv python find "$PYTHON_VERSION" >/dev/null 2>&1; then
  log_skip "Python $PYTHON_VERSION already installed"
else
  log_info "Installing Python $PYTHON_VERSION with uv"
  uv python install "$PYTHON_VERSION"
  record_install python "$PYTHON_VERSION" uv "$(uv python find "$PYTHON_VERSION")"
  ((_INSTALLED++)) || true
  log_success "Python $PYTHON_VERSION installed"
fi

JAVA_VERSION="$(package_version languages java 21)"
if ! is_installed java || ! version_major_matches "$(java -version 2>&1 | head -1 || true)" "$JAVA_VERSION"; then
  apt_install "openjdk-${JAVA_VERSION}-jdk-headless"
else
  log_skip "OpenJDK $JAVA_VERSION already installed"
fi

print_summary "Languages & Runtimes"
