#!/usr/bin/env bash
if [[ -z "${DOTFILES_SOURCE_DIR:-}" ]]; then
  DOTFILES_SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
fi
# shellcheck source=scripts/lib.sh
source "$DOTFILES_SOURCE_DIR/scripts/lib.sh"

log_step "Installing Languages & Runtimes"

require_sudo
ARCH=$(get_arch)

# ── Go ────────────────────────────────────────────────────────────────────────
GO_VERSION="$(package_version languages go 1.24.3)"
if [[ -d /usr/local/go/bin ]]; then
  export PATH="/usr/local/go/bin:$PATH"
fi
if ! is_installed go || [[ "$(go version 2>/dev/null | grep -oP '\d+\.\d+\.\d+')" != "$GO_VERSION" ]]; then
  log_info "Installing Go ${GO_VERSION}..."
  curl -fsSLo /tmp/go.tar.gz "https://dl.google.com/go/go${GO_VERSION}.linux-${ARCH}.tar.gz"
  sudo rm -rf /usr/local/go
  sudo tar -C /usr/local -xzf /tmp/go.tar.gz
  rm -f /tmp/go.tar.gz
  export PATH="/usr/local/go/bin:$PATH"
  log_success "Go $(/usr/local/go/bin/go version | grep -oP '\d+\.\d+\.\d+') installed"
else
  log_skip "Go ${GO_VERSION} already installed"
fi

# ── Rust + Cargo ──────────────────────────────────────────────────────────────
RUST_VERSION="$(package_version languages rust stable)"
CARGO_VERSION="$(package_version languages cargo stable)"
if ! is_installed rustc || ! is_installed cargo; then
  log_info "Installing Rust/Cargo toolchain ${RUST_VERSION}..."
  curl -fsSL https://sh.rustup.rs | sh -s -- -y --default-toolchain "$RUST_VERSION"
  source "$HOME/.cargo/env"
  log_success "Rust $(rustc --version | awk '{print $2}') installed"
else
  [[ -f "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"
  if is_installed rustup && [[ "$RUST_VERSION" != "stable" ]]; then
    rustup toolchain install "$RUST_VERSION"
    rustup default "$RUST_VERSION"
  fi
  log_skip "Rust/Cargo ${CARGO_VERSION} already installed"
fi


# ── Node.js via nvm ──────────────────────────────────────────────────────────
NODE_VERSION="$(package_version languages node_lts 24.15.0)"
TYPESCRIPT_VERSION="$(package_version languages typescript 5.9.3)"
export NVM_DIR="$HOME/.nvm"
if [[ ! -d "$NVM_DIR" ]]; then
  log_info "Installing nvm..."
  curl -fsSLo- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.3/install.sh | bash
  log_success "nvm installed"
fi
# Source nvm
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
if ! nvm ls "$NODE_VERSION" &>/dev/null; then
  log_info "Installing Node.js ${NODE_VERSION}..."
  nvm install "$NODE_VERSION"
  nvm alias default "$NODE_VERSION"
  log_success "Node.js $(node --version) installed"
else
  nvm use "$NODE_VERSION" >/dev/null
  log_skip "Node.js ${NODE_VERSION} already installed"
fi

if ! is_installed tsc || [[ "$(tsc --version 2>/dev/null | awk '{print $2}')" != "$TYPESCRIPT_VERSION" ]]; then
  log_info "Installing TypeScript ${TYPESCRIPT_VERSION}..."
  npm install -g "typescript@${TYPESCRIPT_VERSION}"
  log_success "TypeScript $(tsc --version | awk '{print $2}') installed"
else
  log_skip "TypeScript ${TYPESCRIPT_VERSION} already installed"
fi

# ── Python (uv) ──────────────────────────────────────────────────────────────
PYTHON_VERSION="$(package_version languages python 3.14.5)"
if ! is_installed uv; then
  log_info "Installing uv (Python package manager)..."
  curl -LsSf https://astral.sh/uv/install.sh | sh
  export PATH="$HOME/.local/bin:$PATH"
  log_success "uv installed"
else
  log_skip "uv already installed"
fi

PYTHON_MINOR="${PYTHON_VERSION%.*}"
if ! uv python find "$PYTHON_VERSION" &>/dev/null; then
  log_info "Installing Python ${PYTHON_VERSION} with uv..."
  if uv python install "$PYTHON_VERSION"; then
    log_success "Python $(uv python find "$PYTHON_VERSION") installed"
  else
    log_warn "Python ${PYTHON_VERSION} is not available from uv yet; installing latest ${PYTHON_MINOR}.x"
    uv python install "$PYTHON_MINOR"
    log_success "Python $(uv python find "$PYTHON_MINOR") installed"
  fi
else
  log_skip "Python ${PYTHON_VERSION} already installed"
fi

# ── Java ──────────────────────────────────────────────────────────────────────
JAVA_VERSION="$(package_version languages java 21)"
if ! is_installed java || ! java -version 2>&1 | grep -q "${JAVA_VERSION}"; then
  log_info "Installing OpenJDK ${JAVA_VERSION}..."
  sudo apt-get install -y "openjdk-${JAVA_VERSION}-jdk-headless"
  log_success "Java $(java -version 2>&1 | head -1 | awk -F '"' '{print $2}') installed"
else
  log_skip "OpenJDK ${JAVA_VERSION} already installed"
fi

print_summary "Languages & Runtimes"
