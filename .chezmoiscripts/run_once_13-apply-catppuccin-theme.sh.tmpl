#!/usr/bin/env bash
if [[ -z "${DOTFILES_SOURCE_DIR:-}" ]]; then
  DOTFILES_SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
fi
# shellcheck source=scripts/lib.sh
source "$DOTFILES_SOURCE_DIR/scripts/lib.sh"

log_step "Applying Catppuccin Mocha Theme"

BTOP_COMMIT=f437574b600f1c6d932627050b15ff5153b58fa3
BTOP_SHA=4c7469ab9bda282c1ff606aca37c9c0b84cd0cb66d041e4e7e1fed39791f4644
BTOP_THEME="$HOME/.config/btop/themes/catppuccin_mocha.theme"
if [[ ! -f "$BTOP_THEME" ]] || ! verify_sha256 "$BTOP_THEME" "$BTOP_SHA" >/dev/null 2>&1; then
  mkdir -p "$(dirname "$BTOP_THEME")"
  download_verified \
    "https://raw.githubusercontent.com/catppuccin/btop/${BTOP_COMMIT}/themes/catppuccin_mocha.theme" \
    "$BTOP_THEME" "sha256:$BTOP_SHA" catppuccin_mocha.theme
  record_install btop-theme "$BTOP_COMMIT" github:catppuccin/btop "$BTOP_THEME"
else
  log_skip "btop theme already verified"
fi

LAZYGIT_CONFIG="$HOME/.config/lazygit/config.yml"
if [[ ! -f "$LAZYGIT_CONFIG" ]]; then
  mkdir -p "$(dirname "$LAZYGIT_CONFIG")"
  install -m 0600 /dev/null "$LAZYGIT_CONFIG"
  cat > "$LAZYGIT_CONFIG" <<'EOF'
gui:
  nerdFontsVersion: "3"
  theme:
    activeBorderColor: ["#89b4fa", bold]
    inactiveBorderColor: ["#45475a"]
    optionsTextColor: ["#89b4fa"]
    selectedLineBgColor: ["#313244"]
    unstagedChangesColor: ["#f38ba8"]
    defaultFgColor: ["#cdd6f4"]
EOF
  record_install lazygit-theme local dotfiles "$LAZYGIT_CONFIG"
  log_success "lazygit theme created"
else
  log_skip "Existing lazygit config preserved"
fi

if is_native; then
  KITTY_COMMIT=43098316202b84d6a71f71aaf8360f102f4d3f1a
  KITTY_SHA=716ac97cd542bae4ff35b53ca980aae4f001e0c4bc59c4fbe003019be20ef9cd
  KITTY_THEME="$HOME/.config/kitty/themes/catppuccin_mocha.conf"
  if [[ ! -f "$KITTY_THEME" ]] || ! verify_sha256 "$KITTY_THEME" "$KITTY_SHA" >/dev/null 2>&1; then
    mkdir -p "$(dirname "$KITTY_THEME")"
    download_verified \
      "https://raw.githubusercontent.com/catppuccin/kitty/${KITTY_COMMIT}/themes/mocha.conf" \
      "$KITTY_THEME" "sha256:$KITTY_SHA" mocha.conf
    record_install kitty-theme "$KITTY_COMMIT" github:catppuccin/kitty "$KITTY_THEME"
  else
    log_skip "Kitty theme already verified"
  fi
fi

log_info "Starship, FZF, tmux, and Neovim themes are repository-managed"
print_summary "Catppuccin Mocha Theme"
