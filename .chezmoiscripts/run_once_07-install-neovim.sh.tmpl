#!/usr/bin/env bash
if [[ -z "${DOTFILES_SOURCE_DIR:-}" ]]; then
  DOTFILES_SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
fi
# shellcheck source=scripts/lib.sh
source "$DOTFILES_SOURCE_DIR/scripts/lib.sh"

log_step "Installing Neovim"

NVIM_VERSION="$(package_version editor neovim 0.12.4)"
case "$(get_arch)" in
  amd64)
    NVIM_ARCH=x86_64
    ;;
  arm64)
    NVIM_ARCH=arm64
    ;;
  *) log_error "Unsupported Neovim architecture: $(get_arch)"; exit 1 ;;
esac
NVIM_SHA="$(package_metadata editor neovim "sha256_$(get_arch)")"

NVIM_ROOT="$HOME/.local/share/dotfiles/tools/neovim/$NVIM_VERSION"
if [[ ! -x "$NVIM_ROOT/bin/nvim" ]] || ! version_ge "$($NVIM_ROOT/bin/nvim --version 2>/dev/null | head -1 || true)" "$NVIM_VERSION"; then
  tmpdir="$(mktemp -d)"
  asset="nvim-linux-${NVIM_ARCH}.tar.gz"
  log_info "Installing verified Neovim $NVIM_VERSION"
  download_verified \
    "https://github.com/neovim/neovim/releases/download/v${NVIM_VERSION}/$asset" \
    "$tmpdir/$asset" "sha256:$NVIM_SHA" "$asset"
  rm -rf "$NVIM_ROOT"
  mkdir -p "$NVIM_ROOT"
  tar -xzf "$tmpdir/$asset" -C "$NVIM_ROOT" --strip-components=1
  rm -rf "$tmpdir"
  record_install nvim "$NVIM_VERSION" github:neovim/neovim "$NVIM_ROOT"
  ((_INSTALLED++)) || true
  log_success "Neovim $NVIM_VERSION installed"
else
  log_skip "Neovim $NVIM_VERSION already installed"
fi
managed_link "$NVIM_ROOT/bin/nvim" "$HOME/.local/bin/nvim" nvim "$NVIM_VERSION"

"$HOME/.local/bin/nvim" --clean --headless '+lua assert(vim.version().minor >= 12)' +qa
log_success "Neovim headless runtime validation passed"
log_info "Run scripts/validate-neovim.sh --sync to install and verify locked plugins"

print_summary "Neovim"
