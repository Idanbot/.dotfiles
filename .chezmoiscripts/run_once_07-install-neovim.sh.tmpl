#!/usr/bin/env bash
if [[ -z "${DOTFILES_SOURCE_DIR:-}" ]]; then
  DOTFILES_SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
fi
# shellcheck source=scripts/lib.sh
source "$DOTFILES_SOURCE_DIR/scripts/lib.sh"

log_step "Installing Neovim"

require_sudo
ARCH=$(get_arch)

NVIM_REQUESTED="$(package_version editor neovim latest)"
if [[ "$NVIM_REQUESTED" == "latest" ]]; then
  NVIM_VERSION="$(resolve_tool_version neovim/neovim latest)"
elif [[ "$NVIM_REQUESTED" == v* ]]; then
  NVIM_VERSION="$NVIM_REQUESTED"
else
  NVIM_VERSION="v$NVIM_REQUESTED"
fi
NVIM_TARGET="${NVIM_VERSION#v}"
NVIM_CURRENT=""
if is_installed nvim; then
  NVIM_CURRENT="$(nvim --version 2>/dev/null | awk 'NR == 1 {print $2}' | sed 's/^v//')"
fi

if ! is_installed nvim || ! version_ge "$NVIM_CURRENT" "$NVIM_TARGET"; then
  log_info "Installing Neovim ${NVIM_VERSION}..."
  if [[ "$ARCH" == "amd64" ]]; then
    curl -fsSLo /tmp/nvim.appimage "https://github.com/neovim/neovim/releases/download/${NVIM_VERSION}/nvim-linux-x86_64.appimage"
    chmod +x /tmp/nvim.appimage
    sudo install /tmp/nvim.appimage /usr/local/bin/nvim
    rm -f /tmp/nvim.appimage
  else
    log_warn "Neovim AppImage is only configured for amd64; installing distro package"
    sudo apt-get install -y neovim
  fi
  log_success "Neovim $(nvim --version | awk 'NR == 1 {print $2}') installed"
else
  log_skip "Neovim ${NVIM_TARGET} already installed"
fi

# LazyVim will bootstrap itself on first launch from ~/.config/nvim/
log_info "LazyVim will auto-install plugins on first nvim launch"

print_summary "Neovim"
