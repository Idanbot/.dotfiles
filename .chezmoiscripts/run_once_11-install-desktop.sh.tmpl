#!/usr/bin/env bash
if [[ -z "${DOTFILES_SOURCE_DIR:-}" ]]; then
  DOTFILES_SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
fi
# shellcheck source=scripts/lib.sh
source "$DOTFILES_SOURCE_DIR/scripts/lib.sh"

log_step "Installing Desktop Tools"
if is_wsl; then
  log_skip "Desktop tools are disabled on WSL"
  print_summary "Desktop Tools"
  exit 0
fi

require_sudo
apt_install kitty
if is_installed gnome-shell; then
  apt_install gnome-tweaks gnome-shell-extension-manager
else
  log_skip "GNOME is not present"
fi
log_info "Ghostty and GNOME extension authentication/install choices remain manual"

print_summary "Desktop Tools"
