#!/usr/bin/env bash
if [[ -z "${DOTFILES_SOURCE_DIR:-}" ]]; then
  DOTFILES_SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
fi
# shellcheck source=scripts/lib.sh
source "$DOTFILES_SOURCE_DIR/scripts/lib.sh"

log_step "Installing Core Packages"

require_sudo

# Do not rewrite a user's mirror choices. Retry the configured signed sources.
apt_update

apt_install \
  git \
  curl \
  wget \
  jq \
  yq \
  make \
  build-essential \
  unzip \
  zip \
  tar \
  gzip \
  software-properties-common \
  apt-transport-https \
  ca-certificates \
  gnupg \
  lsb-release \
  xclip \
  xsel \
  tree \
  net-tools \
  dnsutils \
  whois \
  nmap \
  traceroute \
  stow \
  file \
  less \
  man-db \
  openssh-client \
  python3 \
  python3-pip \
  python3-venv \
  poppler-utils \
  chafa \
  zoxide \
  direnv \
  git-delta \
  hyperfine \
  duf

print_summary "Core Packages"
