#!/usr/bin/env bash
source "{{ .chezmoi.sourceDir }}/scripts/lib.sh"

log_step "Installing Tmux Ecosystem"

require_sudo

# Install tmux
apt_install tmux

# Install tmuxp
if ! is_installed tmuxp; then
  log_info "Installing tmuxp..."
  pip3 install --user tmuxp 2>/dev/null || pipx install tmuxp 2>/dev/null || {
    if is_installed uv; then
      uv tool install tmuxp
    else
      log_warn "Could not install tmuxp — install manually"
    fi
  }
  log_success "tmuxp installed"
else
  log_skip "tmuxp already installed"
fi

# TPM is handled by .chezmoiexternal.yaml
if [[ -d "$HOME/.tmux/plugins/tpm" ]]; then
  log_success "TPM installed (via chezmoi externals)"
  # Install tmux plugins
  log_info "Installing tmux plugins via TPM..."
  "$HOME/.tmux/plugins/tpm/bin/install_plugins" 2>/dev/null || log_warn "TPM plugin install skipped (tmux may not be running)"
else
  log_warn "TPM not yet installed — will be set up by chezmoi externals"
fi

print_summary "Tmux Ecosystem"
