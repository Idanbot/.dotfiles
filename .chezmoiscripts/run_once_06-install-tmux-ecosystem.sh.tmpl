#!/usr/bin/env bash
if [[ -z "${DOTFILES_SOURCE_DIR:-}" ]]; then
  DOTFILES_SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
fi
# shellcheck source=scripts/lib.sh
source "$DOTFILES_SOURCE_DIR/scripts/lib.sh"

log_step "Installing Tmux Ecosystem"
require_sudo
apt_install tmux

TMUXP_VERSION="$(package_version terminal tmuxp 1.74.0)"
if ! is_installed uvx; then
  log_error "uvx is required for reproducible tmuxp workspaces; include the languages section"
  exit 1
fi
log_info "Prewarming tmuxp $TMUXP_VERSION through uvx"
uvx --from "tmuxp==${TMUXP_VERSION}" tmuxp --version
record_install tmuxp "$TMUXP_VERSION" uvx "$(uv cache dir)/archive-v0"
log_success "tmuxp $TMUXP_VERSION is available through uvx"

if [[ -x "$HOME/.tmux/plugins/tpm/bin/install_plugins" ]]; then
  log_info "Installing missing TPM plugins"
  "$HOME/.tmux/plugins/tpm/bin/install_plugins" || log_warn "TPM deferred plugin installation"
else
  log_error "Checksum-pinned TPM external is missing"
fi

print_summary "Tmux Ecosystem"
