#!/usr/bin/env bash
if [[ -z "${DOTFILES_SOURCE_DIR:-}" ]]; then
  DOTFILES_SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
fi
# shellcheck source=scripts/lib.sh
source "$DOTFILES_SOURCE_DIR/scripts/lib.sh"

log_step "Installing Container & Cloud Tools"
require_sudo
ARCH="$(get_arch)"
case "$ARCH" in
  amd64) RELEASE_ARCH=amd64; HASHI_ARCH=amd64; AWS_ARCH=x86_64 ;;
  arm64) RELEASE_ARCH=arm64; HASHI_ARCH=arm64; AWS_ARCH=aarch64 ;;
  *) log_error "Unsupported cloud-tool architecture: $ARCH"; exit 1 ;;
esac

# Ubuntu's signed packages are the sole Docker owner. On WSL, Docker Desktop
# supplies the daemon; on native Ubuntu docker.io supplies both CLI and daemon.
apt_install docker.io docker-compose-v2
if is_installed docker && [[ ! -f /usr/share/zsh/vendor-completions/_docker ]]; then
  sudo mkdir -p /usr/share/zsh/vendor-completions
  docker completion zsh | sudo tee /usr/share/zsh/vendor-completions/_docker >/dev/null
  log_success "Generated Docker zsh completion from the installed CLI"
fi
if is_native && is_installed docker; then
  sudo usermod -aG docker "$(whoami)" || true
  log_warn "Docker group changes take effect after the next login"
fi

KUBECTL_VERSION="$(package_version cloud kubectl 1.36.2)"
if ! is_installed kubectl || ! version_ge "$(kubectl version --client 2>/dev/null | head -1 || true)" "$KUBECTL_VERSION"; then
  tmpdir="$(mktemp -d)"
  url="https://dl.k8s.io/release/v${KUBECTL_VERSION}/bin/linux/${RELEASE_ARCH}/kubectl"
  log_info "Installing kubectl $KUBECTL_VERSION"
  download_verified "$url" "$tmpdir/kubectl" "$url.sha256" kubectl
  install_managed_binary "$tmpdir/kubectl" kubectl "$KUBECTL_VERSION" dl.k8s.io
  rm -rf "$tmpdir"
  ((_INSTALLED++)) || true
else
  log_skip "kubectl $KUBECTL_VERSION already installed or newer"
fi

HELM_VERSION="$(package_version cloud helm 4.2.3)"
if ! is_installed helm || ! version_ge "$(helm version --short 2>/dev/null || true)" "$HELM_VERSION"; then
  tmpdir="$(mktemp -d)"
  asset="helm-v${HELM_VERSION}-linux-${RELEASE_ARCH}.tar.gz"
  url="https://get.helm.sh/$asset"
  log_info "Installing Helm $HELM_VERSION"
  download_verified "$url" "$tmpdir/$asset" "$url.sha256sum" "$asset"
  tar -xzf "$tmpdir/$asset" -C "$tmpdir"
  install_managed_binary "$tmpdir/linux-${RELEASE_ARCH}/helm" helm "$HELM_VERSION" get.helm.sh
  rm -rf "$tmpdir"
  ((_INSTALLED++)) || true
else
  log_skip "Helm $HELM_VERSION already installed or newer"
fi

TERRAFORM_VERSION="$(package_version cloud terraform 1.15.8)"
if ! is_installed terraform || ! version_ge "$(terraform version 2>/dev/null | head -1 || true)" "$TERRAFORM_VERSION"; then
  tmpdir="$(mktemp -d)"
  asset="terraform_${TERRAFORM_VERSION}_linux_${HASHI_ARCH}.zip"
  base="https://releases.hashicorp.com/terraform/${TERRAFORM_VERSION}"
  log_info "Installing Terraform $TERRAFORM_VERSION"
  download_verified "$base/$asset" "$tmpdir/$asset" \
    "$base/terraform_${TERRAFORM_VERSION}_SHA256SUMS" "$asset"
  unzip -q "$tmpdir/$asset" -d "$tmpdir"
  install_managed_binary "$tmpdir/terraform" terraform "$TERRAFORM_VERSION" releases.hashicorp.com
  rm -rf "$tmpdir"
  ((_INSTALLED++)) || true
else
  log_skip "Terraform $TERRAFORM_VERSION already installed or newer"
fi

apt_install ansible

K9S_VERSION="$(package_version cloud k9s 0.51.0)"
install_github_archive \
  k9s derailed/k9s "v${K9S_VERSION#v}" \
  "k9s_Linux_${RELEASE_ARCH}.tar.gz" k9s \
  "https://github.com/derailed/k9s/releases/download/{tag}/checksums.sha256" \
  'k9s version --short'

AWS_VERSION="$(package_version cloud aws_cli 2.34.54)"
AWS_CURRENT="$(aws --version 2>/dev/null || true)"
if ! is_installed aws || ! version_ge "$AWS_CURRENT" "$AWS_VERSION"; then
  AWS_SHA="$(package_metadata cloud aws_cli "sha256_$ARCH")"
  tmpdir="$(mktemp -d)"
  asset="awscli-exe-linux-${AWS_ARCH}-${AWS_VERSION}.zip"
  log_info "Installing AWS CLI $AWS_VERSION"
  download_verified "https://awscli.amazonaws.com/$asset" "$tmpdir/$asset" "sha256:$AWS_SHA" "$asset"
  unzip -q "$tmpdir/$asset" -d "$tmpdir"
  if is_installed aws; then
    sudo "$tmpdir/aws/install" --update
  else
    sudo "$tmpdir/aws/install"
  fi
  rm -rf "$tmpdir"
  record_install aws "$AWS_VERSION" aws-installer /usr/local/aws-cli
  ((_INSTALLED++)) || true
  log_success "AWS CLI $AWS_VERSION installed"
else
  log_skip "AWS CLI $AWS_VERSION already installed or newer"
fi

if ! is_installed gcloud; then
  log_info "Configuring Google Cloud's signed apt repository"
  sudo mkdir -p /usr/share/keyrings
  install_apt_key \
    https://packages.cloud.google.com/apt/doc/apt-key.gpg \
    /usr/share/keyrings/cloud.google.gpg \
    35BAA0B33E9EB396F59CA838C0BA5CE6DC6315A3
  printf '%s\n' \
    'deb [signed-by=/usr/share/keyrings/cloud.google.gpg] https://packages.cloud.google.com/apt cloud-sdk main' |
    sudo tee /etc/apt/sources.list.d/google-cloud-sdk.list >/dev/null
  apt_update
  apt_install google-cloud-cli
else
  log_skip "Google Cloud CLI already installed"
fi

if ! is_installed az; then
  log_info "Configuring Microsoft's signed Azure CLI apt repository"
  sudo mkdir -p /etc/apt/keyrings
  install_apt_key \
    https://packages.microsoft.com/keys/microsoft.asc \
    /etc/apt/keyrings/microsoft.gpg \
    BC528686B50D79E339D3721CEB3E94ADBE1229CF
  printf 'deb [arch=%s signed-by=/etc/apt/keyrings/microsoft.gpg] https://packages.microsoft.com/repos/azure-cli/ %s main\n' \
    "$(dpkg --print-architecture)" "$(. /etc/os-release; printf '%s' "$VERSION_CODENAME")" |
    sudo tee /etc/apt/sources.list.d/azure-cli.list >/dev/null
  apt_update
  apt_install azure-cli
else
  log_skip "Azure CLI already installed"
fi

if ! is_installed cloudflared; then
  log_info "Installing cloudflared..."
  CF_ARCH=$(get_arch)
  download "https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-${CF_ARCH}.deb" /tmp/cloudflared.deb
  sudo dpkg -i /tmp/cloudflared.deb
  rm -f /tmp/cloudflared.deb
  log_success "cloudflared installed"
else
  log_skip "cloudflared already installed"
fi

STERN_VERSION="$(package_version cloud stern 1.32.0)"
install_github_archive \
  stern stern/stern "v${STERN_VERSION#v}" \
  "stern_${STERN_VERSION}_linux_${ARCH}.tar.gz" stern \
  "https://github.com/stern/stern/releases/download/{tag}/checksums.txt" \
  'stern --version'

USQL_VERSION="$(package_version database usql 0.19.16)"
install_github_archive \
  usql xo/usql "v${USQL_VERSION#v}" \
  "usql-${USQL_VERSION}-linux-${ARCH}.tar.bz2" usql \
  "" \
  'usql --version'

if ! is_installed iredis; then
  if is_installed uv; then
    log_info "Installing iredis via uv..."
    uv tool install iredis --quiet 2>/dev/null || pip install --user iredis 2>/dev/null || true
    log_success "iredis installed"
  fi
else
  log_skip "iredis already installed"
fi

# Pre-generate offline Zsh completion definitions for kubectl, helm, docker
mkdir -p "$HOME/.zsh/completions"
if is_installed kubectl; then
  kubectl completion zsh > "$HOME/.zsh/completions/_kubectl" 2>/dev/null || true
fi
if is_installed helm; then
  helm completion zsh > "$HOME/.zsh/completions/_helm" 2>/dev/null || true
fi
if is_installed docker; then
  docker completion zsh > "$HOME/.zsh/completions/_docker" 2>/dev/null || true
fi

log_info "Cloud authentication is intentionally not automated"
print_summary "Container & Cloud Tools"
