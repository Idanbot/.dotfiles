#!/usr/bin/env bash
if [[ -z "${DOTFILES_SOURCE_DIR:-}" ]]; then
  DOTFILES_SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
fi
# shellcheck source=scripts/lib.sh
source "$DOTFILES_SOURCE_DIR/scripts/lib.sh"

log_step "Configuring System"
require_sudo

if [[ "${SHELL:-}" == *zsh* ]]; then
  log_skip "Zsh is already the login shell"
elif is_installed zsh; then
  if is_ci; then
    log_skip "Login-shell mutation skipped in CI"
  else
    chsh -s "$(command -v zsh)"
    log_success "Zsh selected as the login shell"
  fi
else
  log_error "Zsh is unavailable"
fi

GCM_VERSION="$(package_version system git_credential_manager 2.8.0)"
if ! is_installed git-credential-manager || ! version_ge "$(git-credential-manager --version 2>/dev/null || true)" "$GCM_VERSION"; then
  case "$(get_arch)" in
    amd64)
      GCM_ARCH=x64
      GCM_SHA=c7bbf9785c3e8166ceedb66a7e0bfb40e6655ef504af5ca7977b516c5497aff6
      ;;
    arm64)
      GCM_ARCH=arm64
      GCM_SHA=e5bbc12c31e97a7409585ef60aa5d53138c7661d9a3abc9227d9b0f68959e836
      ;;
  esac
  tmpdir="$(mktemp -d)"
  asset="gcm-linux-${GCM_ARCH}-${GCM_VERSION}.deb"
  log_info "Installing Git Credential Manager $GCM_VERSION"
  download_verified \
    "https://github.com/git-ecosystem/git-credential-manager/releases/download/v${GCM_VERSION}/$asset" \
    "$tmpdir/$asset" "sha256:$GCM_SHA" "$asset"
  sudo dpkg -i "$tmpdir/$asset" || apt_env apt-get -f -y install
  rm -rf "$tmpdir"
  git-credential-manager configure || true
  record_install git-credential-manager "$GCM_VERSION" dpkg gcm
  ((_INSTALLED++)) || true
  log_success "Git Credential Manager $GCM_VERSION installed"
else
  log_skip "Git Credential Manager $GCM_VERSION already installed or newer"
fi

if is_native && is_installed kitty; then
  sudo update-alternatives --install \
    /usr/bin/x-terminal-emulator x-terminal-emulator "$(command -v kitty)" 50 || true
fi

print_summary "System Configuration"
