#!/usr/bin/env bash
# run_once_before_02b-fix-omz-git-wsl.sh.tmpl
#
# WSL-only — no-ops on native Linux.
#
# Problem: OMZ may have been originally installed via the official installer
# (git clone). When chezmoi later took over via .chezmoiexternal.yaml it did
# not remove the .git dir (exact: false). OMZ's built-in updater then tries
# to run git fetch/merge inside ~/.oh-my-zsh, finds a stale .git and leaves
# the index in a broken state:
#
#   error: Your local changes to the following files would be overwritten by merge:
#     .github/workflows/scorecard.yml ...
#   error: you need to resolve your current index first
#
# Fix: remove the .git dir and any leftover merge-state files so chezmoi's
# archive extraction starts clean, and DISABLE_AUTO_UPDATE in .zshrc prevents
# the updater from running again.
{{ if not .is_wsl }}exit 0{{ end }}

OMZ="$HOME/.oh-my-zsh"
backup="$HOME/.local/state/dotfiles/legacy/omz-state-$(date +%Y%m%d%H%M%S)"

if [[ -d "$OMZ/.git" ]]; then
  mkdir -p "$backup"
  echo "[omz-wsl-fix] Preserving stale .git dir at $backup/git"
  mv "$OMZ/.git" "$backup/git"
fi

# Clean up any leftover merge / lock state files
for f in MERGE_HEAD MERGE_MSG MERGE_MODE CHERRY_PICK_HEAD index.lock; do
  if [[ -f "$OMZ/$f" ]]; then
    mkdir -p "$backup"
    mv "$OMZ/$f" "$backup/$f"
    echo "[omz-wsl-fix] Preserved $OMZ/$f"
  fi
done

echo "[omz-wsl-fix] Done"
