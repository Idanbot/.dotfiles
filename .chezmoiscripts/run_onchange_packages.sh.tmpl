#!/usr/bin/env bash
# This script re-runs whenever packages.yaml changes
# hash: {{ include "packages.yaml" | sha256sum }}
if [[ -z "${DOTFILES_SOURCE_DIR:-}" ]]; then
  DOTFILES_SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
fi
# shellcheck source=scripts/lib.sh
source "$DOTFILES_SOURCE_DIR/scripts/lib.sh"

log_step "Reconciling Changed Package Sections"

log_info "packages.yaml changed; routing only affected manifest sections"
"$DOTFILES_SOURCE_DIR/scripts/reconcile-packages.sh"

print_summary "Package Update Check"
