#!/usr/bin/env bash
if [[ -z "${DOTFILES_SOURCE_DIR:-}" ]]; then
  DOTFILES_SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
fi
# shellcheck source=scripts/lib.sh
source "$DOTFILES_SOURCE_DIR/scripts/lib.sh"

log_step "Installing AI Coding Tools (Optional)"

# ── Claude CLI ────────────────────────────────────────────────────────────────
if ! is_installed claude; then
  log_info "Installing Claude CLI..."
  if is_installed npm; then
    npm install -g @anthropic-ai/claude-cli 2>/dev/null && log_success "Claude CLI installed" || log_warn "Claude CLI install failed"
  else
    log_warn "npm not found — skipping Claude CLI"
  fi
else
  log_skip "Claude CLI already installed"
fi


# ── Codex CLI ─────────────────────────────────────────────────────────────────
if ! is_installed codex; then
  log_info "Installing Codex CLI..."
  if is_installed npm; then
    CODEX_VERSION="$(package_version ai_tools codex_cli latest)"
    if [[ "$CODEX_VERSION" == "latest" ]]; then
      npm install -g @openai/codex 2>/dev/null && log_success "Codex CLI installed" || log_warn "Codex CLI install failed"
    else
      npm install -g "@openai/codex@${CODEX_VERSION}" 2>/dev/null && log_success "Codex CLI ${CODEX_VERSION} installed" || log_warn "Codex CLI install failed"
    fi
  else
    log_warn "npm not found — skipping Codex CLI"
  fi
else
  log_skip "Codex CLI already installed"
fi

# ── Antigravity / Gemini CLI ──────────────────────────────────────────────────
if ! is_installed antigravity && ! is_installed gemini; then
  log_info "Installing Gemini CLI..."
  if is_installed npm; then
    npm install -g @anthropic-ai/antigravity-cli 2>/dev/null || \
    npm install -g @google/gemini-cli 2>/dev/null && log_success "Gemini CLI installed" || \
    log_warn "Gemini CLI install failed — install manually"
  else
    log_warn "npm not found — skipping Gemini CLI"
  fi
else
  log_skip "Gemini/Antigravity CLI already installed"
fi

# ── OpenCode ──────────────────────────────────────────────────────────────────
if ! is_installed opencode; then
  log_info "Installing OpenCode..."
  if is_installed go; then
    go install github.com/opencode-ai/opencode@latest 2>/dev/null && log_success "OpenCode installed" || log_warn "OpenCode install failed"
  else
    log_warn "go not found — skipping OpenCode"
  fi
else
  log_skip "OpenCode already installed"
fi

print_summary "AI Coding Tools"
