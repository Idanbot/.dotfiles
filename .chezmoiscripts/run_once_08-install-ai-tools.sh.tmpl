#!/usr/bin/env bash
if [[ -z "${DOTFILES_SOURCE_DIR:-}" ]]; then
  DOTFILES_SOURCE_DIR="${CHEZMOI_SOURCE_DIR:-$HOME/.local/share/chezmoi}"
fi
# shellcheck source=scripts/lib.sh
source "$DOTFILES_SOURCE_DIR/scripts/lib.sh"

log_step "Installing AI Coding Tools"
activate_node_paths
if ! is_installed npm; then
  log_error "npm is required for the pinned agent packages; include the languages section"
  exit 1
fi

CLAUDE_VERSION="$(package_version ai_tools claude_cli 2.1.206)"
npm_install_global @anthropic-ai/claude-code "$CLAUDE_VERSION" claude

CODEX_INSTALLER_SHA=1154e9daf713aacd1534efca8042bfd6665ad24bc1d1dfd86b8f439fe60a7a5d
CODEX_PATH="$(command -v codex 2>/dev/null || true)"
if [[ -z "$CODEX_PATH" || "$CODEX_PATH" == "$HOME/.nvm/"* ]]; then
  tmpdir="$(mktemp -d)"
  log_info "Installing Codex CLI with OpenAI's standalone installer"
  download_verified \
    https://chatgpt.com/codex/install.sh "$tmpdir/codex-install.sh" \
    "sha256:$CODEX_INSTALLER_SHA" codex-install.sh
  sh "$tmpdir/codex-install.sh"
  rm -rf "$tmpdir"
  export PATH="$HOME/.local/bin:$PATH"
  is_installed codex || { log_error "Codex standalone installer did not expose codex in PATH"; exit 1; }
  record_install codex "$(codex --version 2>/dev/null | head -1 || printf standalone)" openai-installer "$(command -v codex)"
  ((_INSTALLED++)) || true
  log_success "Codex standalone CLI installed"
else
  log_skip "Codex standalone CLI already installed"
fi

GEMINI_VERSION="$(package_version ai_tools gemini_cli 0.50.0)"
npm_install_global @google/gemini-cli "$GEMINI_VERSION" gemini

OPENCODE_VERSION="$(package_version ai_tools opencode 1.17.18)"
npm_install_global opencode-ai "$OPENCODE_VERSION" opencode

OMP_VERSION="$(package_version ai_tools omp 16.4.0)"
case "$(get_arch)" in
  amd64)
    OMP_ASSET=omp-linux-x64
    OMP_SHA256=c7a2fa328c965131c0d0ef62a07a4fe63306ed1b7a90fbbb924c75605c68d38a
    ;;
  arm64)
    OMP_ASSET=omp-linux-arm64
    OMP_SHA256=6bb8d76fa25ebea08b2ce87a79387c1dd0bcbff5564ef5bc79f2595a870a3a68
    ;;
esac
install_github_binary omp can1357/oh-my-pi "v$OMP_VERSION" "$OMP_ASSET" omp \
  "sha256:$OMP_SHA256" 'omp --version'

if is_installed antigravity; then
  log_skip "Antigravity CLI is already available"
else
  log_warn "Antigravity has no approved automated installer in this repository; install it manually"
fi

for agent in claude codex gemini opencode omp; do
  if "$agent" --version >/dev/null 2>&1; then
    log_success "$agent executable validation passed"
  else
    log_error "$agent failed its noninteractive version check"
  fi
done
log_info "Agent authentication and session state are intentionally left to the user"

print_summary "AI Coding Tools"
